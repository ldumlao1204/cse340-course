<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

        <h2>Welcome to the CSE 340 Service Network!</h2>
        <p>Our mission is to promote service across the world by connecting volunteers with service opportunities in their
            community.</p>

        <section class="hero" aria-labelledby="home-title">
            <h2 id="home-title">Connect volunteers with meaningful service.</h2>
            <p>Discover trusted organizations, upcoming projects, and opportunities to make a difference in your community.</p>
            <a class="btn" href="/projects">Explore Projects</a>
        </section>
        
        <section class="card-grid" aria-label="Highlights">
            <article class="card">
                <h2>Partner Organizations</h2>
                <p>Work with community-driven groups that support local impact.</p>
            </article>
        
            <article class="card">
                <h2>Upcoming Service</h2>
                <p>Join events that bring people together for education, cleanup, and outreach.</p>
            </article>
        
            <article class="card">
                <h2>Simple Discovery</h2>
                <p>Browse categories and find the right opportunity quickly and easily.</p>
            </article>
        </section>
    </main>
    
<%- include('partials/footer') %>
