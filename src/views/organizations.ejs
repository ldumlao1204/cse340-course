<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

        <p>Here are a few of our partner organizations:</p>

        <section class="card-grid" aria-label="Partner organizations">
            <% organizations.forEach(org => { %>
                <article class="card organization-card">
                    <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo" class="card-image">
                    <div class="card-title">
                        <h2><%= org.name %></h2>
                    </div>
                    <p><%= org.description %></p>
                    <p><strong>Contact:</strong> <a href="mailto:<%= org.contact_email %>"><%= org.contact_email %></a></p>
                </article>
            <% }) %>
        </section>
    </main>
    
<%- include('partials/footer') %>