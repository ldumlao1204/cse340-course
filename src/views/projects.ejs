<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

        <h2>Join Us and be Part of Our Service Projects</h2>
        <section class="card-grid" aria-label="Service projects">
            <% projects.forEach(project => { %>
                <article class="card">
                    <p>
                        <strong>
                            <%= new Date(project.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
                        </strong>
                        :
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                        (
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                        )
                    </p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                    <p><%= project.description %></p>
                </article>
            <% }) %>
        </section>
    </main>

<%- include('partials/footer') %>