<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

        <h2>Service Project Categories</h2>
        <section class="card-grid" aria-label="Service project categories">
            <% categories.forEach(category => { %>
                <article class="card">
                    <div class="card-title">
                        <h3><%= category.name %></h3>
                    </div>
                </article>
            <% }) %>
        </section>
    </main>

<%- include('partials/footer') %>